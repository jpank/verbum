{
  "cards": [
    { "id": "rp-001", "deckId": "retreat-phrases", "polish": "Otwórzmy nasze serca", "english": "Let us open our hearts" },
    { "id": "rp-002", "deckId": "retreat-phrases", "polish": "Proszę o chwilę ciszy", "english": "I ask for a moment of silence" },
    { "id": "rp-003", "deckId": "retreat-phrases", "polish": "Módlmy się", "english": "Let us pray" },
    { "id": "rp-004", "deckId": "retreat-phrases", "polish": "Drodzy bracia i siostry", "english": "Dear brothers and sisters" },
    { "id": "rp-005", "deckId": "retreat-phrases", "polish": "Dzisiejsze czytanie mówi nam o...", "english": "Today's reading tells us about..." },
    { "id": "rp-006", "deckId": "retreat-phrases", "polish": "Bóg nas kocha bezwarunkowo", "english": "God loves us unconditionally" },
    { "id": "rp-007", "deckId": "retreat-phrases", "polish": "Nie bójcie się", "english": "Do not be afraid" },
    { "id": "rp-008", "deckId": "retreat-phrases", "polish": "Jezus mówi do każdego z nas", "english": "Jesus speaks to each one of us" },
    { "id": "rp-009", "deckId": "retreat-phrases", "polish": "Bóg jest z nami w cierpieniu", "english": "God is with us in suffering" },
    { "id": "rp-010", "deckId": "retreat-phrases", "polish": "Pan jest moim pasterzem", "english": "The Lord is my shepherd" },
    { "id": "rp-011", "deckId": "retreat-phrases", "polish": "Ja jestem drogą, prawdą i życiem", "english": "I am the way, the truth and the life" },
    { "id": "rp-012", "deckId": "retreat-phrases", "polish": "Przyjdźcie do Mnie wszyscy", "english": "Come to Me, all of you" },
    { "id": "rp-013", "deckId": "retreat-phrases", "polish": "Gdzie dwaj albo trzej zebrani w imię Moje", "english": "Where two or three are gathered in My name" },
    { "id": "rp-014", "deckId": "retreat-phrases", "polish": "Kto trwa we Mnie, ten przynosi owoc obfity", "english": "Whoever remains in Me bears much fruit" },
    { "id": "rp-015", "deckId": "retreat-phrases", "polish": "Idźcie i nauczajcie wszystkie narody", "english": "Go and make disciples of all nations" },
    { "id": "rp-016", "deckId": "retreat-phrases", "polish": "Ty jesteś Piotr, czyli Skała", "english": "You are Peter, and upon this rock" },
    { "id": "rp-017", "deckId": "retreat-phrases", "polish": "Ojcze, przebacz im, bo nie wiedzą, co czynią", "english": "Father, forgive them, for they know not what they do" },
    { "id": "rp-018", "deckId": "retreat-phrases", "polish": "Wykonało się", "english": "It is finished" },
    { "id": "rp-019", "deckId": "retreat-phrases", "polish": "Pokój wam", "english": "Peace be with you" },
    { "id": "rp-020", "deckId": "retreat-phrases", "polish": "Nie lękajcie się!", "english": "Be not afraid!" },
    { "id": "rp-021", "deckId": "retreat-phrases", "polish": "Wielki Post jest czasem łaski", "english": "Lent is a time of grace" },
    { "id": "rp-022", "deckId": "retreat-phrases", "polish": "Nawracajcie się i wierzcie w Ewangelię", "english": "Repent, and believe in the Gospel" },
    { "id": "rp-023", "deckId": "retreat-phrases", "polish": "Pamiętaj, że prochem jesteś", "english": "Remember that you are dust" },
    { "id": "rp-024", "deckId": "retreat-phrases", "polish": "Będziecie moimi świadkami", "english": "You shall be my witnesses" },
    { "id": "rp-025", "deckId": "retreat-phrases", "polish": "Oto Ja jestem z wami po wszystkie dni", "english": "Behold, I am with you always" },
    { "id": "rp-026", "deckId": "retreat-phrases", "polish": "Niech każdy weźmie swój krzyż", "english": "Let each one take up their cross" },
    { "id": "rp-027", "deckId": "retreat-phrases", "polish": "Bóg jest miłością", "english": "God is love" },
    { "id": "rp-028", "deckId": "retreat-phrases", "polish": "Oto Matka twoja", "english": "Behold, your Mother" },
    { "id": "rp-029", "deckId": "retreat-phrases", "polish": "Pan zmartwychwstał!", "english": "The Lord is risen!" },
    { "id": "rp-030", "deckId": "retreat-phrases", "polish": "Prawdziwie zmartwychwstał!", "english": "He is truly risen!" }
  ]
}
